# whirl test suite. Pure-logic coverage (no network — the transport layer is
# exercised by the real binary). URL parsing + HTTP/1.1 request build / response
# parse / chunked decode.
#
# Stdlib auto-included via cyrius.cyml.

include "src/url.cyr"
include "src/http.cyr"
include "src/links.cyr"

# === URL ===

fn test_url_basic() {
    test_group("url-basic");
    var u = url_new();
    assert_eq(url_parse("http://example.com", u), URL_PARSE_OK, "parse http ok");
    assert_eq(url_is_https(u), 0, "http not https");
    assert_eq(url_port(u), 80, "default port 80");
    assert_eq(streq(url_host(u), "example.com"), 1, "host example.com");
    assert_eq(streq(url_path(u), "/"), 1, "default path /");
}

fn test_url_https_port_path() {
    test_group("url-https");
    var u = url_new();
    assert_eq(url_parse("https://a.b.c:8443/x/y?z=1", u), URL_PARSE_OK, "parse https ok");
    assert_eq(url_is_https(u), 1, "is https");
    assert_eq(url_port(u), 8443, "explicit port 8443");
    assert_eq(streq(url_host(u), "a.b.c"), 1, "host a.b.c");
    assert_eq(streq(url_path(u), "/x/y?z=1"), 1, "path with query preserved");
}

fn test_url_https_default_port() {
    test_group("url-https-default");
    var u = url_new();
    assert_eq(url_parse("https://example.com/", u), URL_PARSE_OK, "ok");
    assert_eq(url_port(u), 443, "default https port 443");
    assert_eq(streq(url_path(u), "/"), 1, "path /");
}

fn test_url_rejects() {
    test_group("url-reject");
    var u = url_new();
    assert_eq(url_parse("ftp://x", u),         URL_PARSE_FAIL, "reject ftp scheme");
    assert_eq(url_parse("http://", u),         URL_PARSE_FAIL, "reject empty host");
    assert_eq(url_parse("http://h:99999/", u), URL_PARSE_FAIL, "reject port > 65535");
    assert_eq(url_parse("notaurl", u),         URL_PARSE_FAIL, "reject missing scheme");
}

# === HTTP ===

fn test_url_filename() {
    test_group("url-filename");
    assert_eq(streq(url_filename("/a/b/file.html"), "file.html"), 1, "last path segment");
    assert_eq(streq(url_filename("/a/b/file.html?x=1"), "file.html"), 1, "strip ?query");
    assert_eq(streq(url_filename("/"), "index.html"), 1, "root -> index.html");
    assert_eq(streq(url_filename("/dir/"), "index.html"), 1, "trailing slash -> index.html");
    assert_eq(streq(url_filename("/just"), "just"), 1, "single segment");
}

fn test_http_build() {
    test_group("http-build");
    var buf = alloc(256);
    var n = http_build_get("example.com", "/", buf, 256);
    assert_eq(_http_match_ci(buf, 0, n, "get / http/1.1"), 1, "request line");
    assert_eq(http_body_offset(buf, n), n, "request ends with CRLFCRLF");
}

fn test_http_status() {
    test_group("http-status");
    var r1 = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nhello";
    assert_eq(http_status_code(r1, strlen(r1)), 200, "status 200");
    var r2 = "HTTP/1.0 404 Not Found\r\n\r\n";
    assert_eq(http_status_code(r2, strlen(r2)), 404, "status 404");
    var r3 = "HTTP/1.1 301 Moved Permanently\r\nLocation: https://x/\r\n\r\n";
    assert_eq(http_status_code(r3, strlen(r3)), 301, "status 301");
}

fn test_http_headers() {
    test_group("http-headers");
    var r = "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nContent-Length: 11\r\n\r\nhello world";
    assert_eq(http_content_length(r, strlen(r)), 11, "content-length 11");
    var bo = http_body_offset(r, strlen(r));
    assert_eq(load8(r + bo), 104, "body starts at 'h'");
    var r2 = "HTTP/1.1 301 X\r\nLocation: http://dst/path\r\n\r\n";
    var lv = http_header_value(r2, strlen(r2), "location");
    assert_eq(_http_match_ci(r2, lv, strlen(r2), "http://dst/path"), 1, "case-insensitive header name");
    assert_eq(http_content_length(r2, strlen(r2)), 0 - 1, "no content-length -> -1");
}

fn test_http_chunked() {
    test_group("http-chunked");
    var r = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n";
    assert_eq(http_is_chunked(r, strlen(r)), 1, "is chunked");
    var bo = http_body_offset(r, strlen(r));
    var out = alloc(64);
    var n = http_dechunk(r + bo, strlen(r) - bo, out, 64);
    assert_eq(n, 11, "dechunk len 11 (hello world)");
    assert_eq(load8(out + 0), 104, "out[0] = h");
    assert_eq(load8(out + 5), 32, "out[5] = space");
    assert_eq(load8(out + 6), 119, "out[6] = w");
}

fn test_http_request_post() {
    test_group("http-request-post");
    var buf = alloc(512);
    var body = "a=1&b=2";
    var n = http_build_request("POST", "x.org", "/p", 0, 0, body, 7, buf, 512);
    assert_eq(_http_match_ci(buf, 0, n, "post /p http/1.1"), 1, "request line = POST /p");
    assert_eq(http_content_length(buf, n), 7, "content-length 7");
    var bo = http_body_offset(buf, n);
    assert_eq(_http_match_ci(buf, bo, n, "a=1&b=2"), 1, "body follows the blank line");
    var ctv = http_header_value(buf, n, "content-type");
    assert_eq(_http_match_ci(buf, ctv, n, "application/x-www-form-urlencoded"), 1, "default content-type");
}

fn test_http_custom_headers() {
    test_group("http-headers-custom");
    var buf = alloc(512);
    var hdrs = alloc(16);
    store64(hdrs + 0, "X-Foo: bar");
    store64(hdrs + 8, "Content-Type: application/json");
    var n = http_build_request("POST", "x.org", "/", hdrs, 2, "{}", 2, buf, 512);
    var xv = http_header_value(buf, n, "x-foo");
    assert_eq(_http_match_ci(buf, xv, n, "bar"), 1, "custom header X-Foo present");
    var ctv = http_header_value(buf, n, "content-type");
    assert_eq(_http_match_ci(buf, ctv, n, "application/json"), 1, "caller Content-Type wins over default");
}

fn test_links() {
    test_group("links");
    var html = "<a href=\"/a.html\">x</a> <img src='img/p.png'> <a href=http://x.org/y>z</a> mysrc=skipme";
    var out = alloc(16 * 8);
    var n = links_extract(html, strlen(html), out, 16);
    assert_eq(n, 3, "3 links (mysrc= skipped at word boundary)");
    assert_eq(streq(load64(out + 0), "/a.html"), 1, "href double-quoted");
    assert_eq(streq(load64(out + 8), "img/p.png"), 1, "src single-quoted");
    assert_eq(streq(load64(out + 16), "http://x.org/y"), 1, "href unquoted");
}

fn test_path_normalize() {
    test_group("path-normalize");
    assert_eq(streq(links_path_normalize("/a/b/../c"), "/a/c"), 1, "../ pops a segment");
    assert_eq(streq(links_path_normalize("/a/./b"), "/a/b"), 1, ". is skipped");
    assert_eq(streq(links_path_normalize("/a/b/../../x"), "/x"), 1, "double ..");
    assert_eq(streq(links_path_normalize("/a/"), "/a/"), 1, "trailing slash kept");
    assert_eq(streq(links_path_normalize("/"), "/"), 1, "root stays /");
    assert_eq(streq(links_path_normalize("/a//b"), "/a/b"), 1, "empty segment collapsed");
}

fn main() {
    alloc_init();
    test_links();
    test_path_normalize();
    test_url_basic();
    test_url_https_port_path();
    test_url_https_default_port();
    test_url_rejects();
    test_url_filename();
    test_http_build();
    test_http_status();
    test_http_headers();
    test_http_chunked();
    test_http_request_post();
    test_http_custom_headers();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
